{
  "name": "balrock-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:base-path": "VITE_PUBLIC_BASE=/balrock/ vite build",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run build && npm run test:smoke && npm run test:smoke:base-path",
    "test:smoke": "playwright test",
    "test:smoke:base-path": "playwright test --config=playwright.base-path.config.js",
    "test:unit": "vitest run",
    "ci": "npm run lint && npm run test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.8",
    "framer-motion": "^12.4.7",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "tailwindcss": "^4.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^29.0.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.1"
  }
}
